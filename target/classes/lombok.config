# Stop zoeken naar lombok.config in parent folders
config.stopBubbling = true

# Gebruik geen @Data automatisch (bewuste keuze)
lombok.data.flagUsage = warning

# Dwing expliciete equals/hashCode keuzes af
lombok.equalsAndHashCode.flagUsage = warning

# Voorkom verrassingen met toString (lazy loading!)
lombok.toString.flagUsage = warning

# Constructor injectie is de norm
lombok.requiredArgsConstructor.flagUsage = allow

# Getter/Setter zijn ok
lombok.getter.flagUsage = allow
lombok.setter.flagUsage = allow

# Builder alleen bewust gebruiken
lombok.builder.flagUsage = allow

# Logging is prima
lombok.log.flagUsage = allow

# Geen @SneakyThrows (verbergt control flow)
lombok.sneakyThrows.flagUsage = error
